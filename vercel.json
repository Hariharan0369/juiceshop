{
  "version": 2,
  "headers": [
    {
      "source": "/(assets|uploads)/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/uploads/(.*)", "destination": "/uploads/$1" },
    { "source": "/(.*)", "destination": "/frontend/dist/$1" }
  ]
}
